<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane fx:id="outerContainer" prefHeight="450.0" prefWidth="450.0" stylesheets="@ClientStyles.css" styleClass="outer-container" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gruppo05.gtwclient.controller.HistoryViewController">
   <children>
      <VBox alignment="CENTER" maxWidth="410.0" maxHeight="410.0" spacing="15.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="history-title" text="Storico Partite" />
            
            <HBox alignment="CENTER" spacing="15.0" styleClass="stats-container">
               <children>
                  <VBox alignment="CENTER" prefWidth="120.0">
                     <children>
                        <Label styleClass="stat-label-played" text="GIOCATE" />
                        <Label fx:id="lblPlayed" styleClass="stat-value-played" text="0" />
                     </children>
                  </VBox>
                  <Separator orientation="VERTICAL" />
                  <VBox alignment="CENTER" prefWidth="120.0">
                     <children>
                        <Label styleClass="stat-label-won" text="VITTORIE" />
                        <Label fx:id="lblWon" styleClass="stat-value-won" text="0" />
                     </children>
                  </VBox>
                  <Separator orientation="VERTICAL" />
                  <VBox alignment="CENTER" prefWidth="120.0">
                     <children>
                        <Label styleClass="stat-label-time" text="TEMPO MEDIO" />
                        <Label fx:id="lblAvgTime" styleClass="stat-value-time" text="0 ms" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            
            <TableView fx:id="tblHistory" prefHeight="230.0" prefWidth="410.0" styleClass="history-table">
              <columns>
                <TableColumn fx:id="colOpponent" prefWidth="120.0" text="Avversario" />
                <TableColumn fx:id="colResult" prefWidth="85.0" text="Esito" />
                <TableColumn fx:id="colDate" prefWidth="110.0" text="Data" />
                <TableColumn fx:id="colTime" prefWidth="80.0" text="Tempo (ms)" />
              </columns>
            </TableView>
            
            <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="410.0">
               <children>
                  <Button fx:id="btnBack" mnemonicParsing="false" onAction="#onBack" prefHeight="35.0" prefWidth="100.0" styleClass="btn-back" text="Indietro" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</StackPane>
