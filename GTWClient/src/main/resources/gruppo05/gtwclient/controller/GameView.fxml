<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<Pane fx:id="outerContainer" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="450.0" prefWidth="450.0" style="-fx-background-color: linear-gradient(to bottom right, #ffffff, #f5f7fa);" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gruppo05.gtwclient.controller.GameViewController">
   <children>
      <VBox layoutX="25.0" layoutY="20.0" prefHeight="410.0" prefWidth="400.0" spacing="15.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="400.0">
               <children>
                  <VBox prefWidth="250.0">
                     <children>
                        <Label fx:id="lblOpponent" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Avversario: -" />
                        <Label fx:id="lblStatus" style="-fx-font-size: 12; -fx-text-fill: #7f8c8d;" text="Stato: In attesa..." />
                        <Label fx:id="lblDifficulty" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-radius: 4; -fx-padding: 2 6 2 6;" text="" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <VBox alignment="CENTER_RIGHT" prefWidth="100.0">
                     <children>
                        <Label style="-fx-font-size: 11; -fx-text-fill: #95a5a6; -fx-font-weight: bold;" text="TEMPO" />
                        <Label fx:id="lblTimer" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" text="--" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            
            <VBox spacing="5.0">
               <children>
                  <Label style="-fx-font-size: 12; -fx-text-fill: #34495e; -fx-font-weight: bold;" text="Frase da indovinare:" />
                  <TextArea fx:id="txaCipheredText" editable="false" prefHeight="150.0" prefWidth="400.0" wrapText="true" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 16; -fx-font-weight: bold; -fx-control-inner-background: #edf2f7; -fx-text-fill: #2c3e50; -fx-background-radius: 6;" />
               </children>
            </VBox>
            
            <VBox spacing="10.0">
               <children>
                  <Label style="-fx-font-size: 12; -fx-text-fill: #34495e; -fx-font-weight: bold;" text="Tua Risposta:" />
                  <TextField fx:id="txfAnswer" prefHeight="40.0" promptText="Inserisci la parola/frase risolutiva" style="-fx-font-size: 14; -fx-background-radius: 6;" />
               </children>
            </VBox>
            
            <HBox alignment="CENTER" prefHeight="50.0" prefWidth="400.0">
               <children>
                  <Button fx:id="btnSubmit" mnemonicParsing="false" onAction="#onSubmit" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-size: 15; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Invia Risposta" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</Pane>
