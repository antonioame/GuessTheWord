<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox fx:id="outerContainer" styleClass="root-container" stylesheets="@AdminDashboard.css" spacing="20.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gruppo05.gtwserver.controller.AdminDashboardViewController">
   <children>
      <!-- Barra di Stato sull'Header -->
      <HBox alignment="CENTER_LEFT" prefHeight="60.0" styleClass="header-box">
         <children>
            <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="title-text" text="Pannello di Controllo Server" />
                  <Label fx:id="lblStatus" styleClass="status-label" text="In ascolto sulla porta: --" />
               </children>
            </VBox>
            <VBox alignment="CENTER_RIGHT">
               <children>
                  <Label fx:id="lblConnectedClients" styleClass="connected-label" text="Client connessi: 0" />
               </children>
            </VBox>
         </children>
      </HBox>
      
      <!-- Area Contenuto Principale -->
      <HBox spacing="20.0" VBox.vgrow="ALWAYS">
         <children>
            <!-- Lato Sinistro: Gestore delle Fonti Testuali -->
            <VBox spacing="10.0" styleClass="panel-box" HBox.hgrow="ALWAYS" minWidth="250.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="panel-title" text="Sorgenti Documenti" />
                  <ListView fx:id="lstSources" styleClass="styled-list-view" VBox.vgrow="ALWAYS" />
                  
                  <HBox spacing="10.0">
                     <children>
                        <Button fx:id="btnAddSource" mnemonicParsing="false" onAction="#onAddSource" styleClass="btn-add" text="Aggiungi TXT" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                        <Button fx:id="btnRemoveSource" mnemonicParsing="false" onAction="#onRemoveSource" styleClass="btn-remove" text="Rimuovi" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                     </children>
                  </HBox>
                  
                  <VBox spacing="5.0" style="-fx-padding: 5 0 0 0;">
                     <children>
                        <HBox alignment="CENTER_LEFT">
                           <children>
                              <Label fx:id="lblAnalysisStatus" styleClass="status-label" text="Stato analisi: Pronto" />
                           </children>
                        </HBox>
                        <ProgressBar fx:id="progressAnalysis" progress="0.0" style="-fx-accent: #2ecc71;" maxWidth="Infinity" />
                     </children>
                  </VBox>
               </children>
            </VBox>
            
            <!-- Lato Destro: Leaderboard / Giocatori -->
            <VBox spacing="10.0" styleClass="panel-box" HBox.hgrow="ALWAYS" minWidth="250.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="panel-title" text="Giocatori e Classifica" />
                  <TableView fx:id="tblPlayers" styleClass="styled-table-view" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colUsername" prefWidth="135.0" text="Username" />
                      <TableColumn fx:id="colWins" prefWidth="90.0" text="Vittorie" />
                      <TableColumn fx:id="colPlayed" prefWidth="90.0" text="Partite" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>
