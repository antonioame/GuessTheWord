<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane fx:id="outerContainer" prefHeight="450.0" prefWidth="450.0" stylesheets="@ClientStyles.css" styleClass="outer-container" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gruppo05.gtwclient.controller.LobbyViewController">
   <children>
      <VBox alignment="CENTER" maxWidth="350.0" maxHeight="330.0" spacing="25.0">
         <children>
            <VBox alignment="CENTER" spacing="10.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="title-text" text="Guess The Word" />
                  <Label fx:id="lblWelcome" styleClass="subtitle-text" text="Benvenuto!" />
               </children>
            </VBox>
            <VBox alignment="CENTER" spacing="15.0" maxWidth="250.0">
               <children>
                  <VBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label styleClass="difficulty-label" text="Seleziona difficoltà:" />
                        <HBox alignment="CENTER" spacing="10.0">
                           <children>
                              <ToggleButton fx:id="btnEasy" mnemonicParsing="false" prefWidth="75.0" styleClass="btn-toggle" text="EASY" />
                              <ToggleButton fx:id="btnNormal" mnemonicParsing="false" prefWidth="75.0" styleClass="btn-toggle" text="NORMAL" />
                              <ToggleButton fx:id="btnHard" mnemonicParsing="false" prefWidth="75.0" styleClass="btn-toggle" text="HARD" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  <Button fx:id="btnPlay" mnemonicParsing="false" onAction="#onPlay" prefHeight="45.0" prefWidth="220.0" styleClass="btn-primary" text="Gioca Partita" />
                  <Button fx:id="btnHistory" mnemonicParsing="false" onAction="#onHistory" prefHeight="45.0" prefWidth="220.0" styleClass="btn-info" text="Storico Partite" />
                  <Button fx:id="btnExit" mnemonicParsing="false" onAction="#onExit" prefHeight="45.0" prefWidth="220.0" styleClass="btn-danger" text="Esci" />
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</StackPane>
