<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<Pane fx:id="outerContainer" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="450.0" prefWidth="450.0" style="-fx-background-color: linear-gradient(to bottom right, #ffffff, #f5f7fa);" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gruppo05.gtwclient.controller.HistoryViewController">
   <children>
      <VBox layoutX="20.0" layoutY="20.0" prefHeight="410.0" prefWidth="410.0" spacing="15.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-fill: #2c3e50;" text="Storico Partite" />
            
            <HBox alignment="CENTER" spacing="15.0" style="-fx-background-color: rgba(255, 255, 255, 0.7); -fx-background-radius: 8; -fx-padding: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 2);">
               <children>
                  <VBox alignment="CENTER" prefWidth="120.0">
                     <children>
                        <Label style="-fx-font-size: 11; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="GIOCATE" />
                        <Label fx:id="lblPlayed" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="0" />
                     </children>
                  </VBox>
                  <Separator orientation="VERTICAL" />
                  <VBox alignment="CENTER" prefWidth="120.0">
                     <children>
                        <Label style="-fx-font-size: 11; -fx-text-fill: #2ecc71; -fx-font-weight: bold;" text="VITTORIE" />
                        <Label fx:id="lblWon" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2ecc71;" text="0" />
                     </children>
                  </VBox>
                  <Separator orientation="VERTICAL" />
                  <VBox alignment="CENTER" prefWidth="120.0">
                     <children>
                        <Label style="-fx-font-size: 11; -fx-text-fill: #3498db; -fx-font-weight: bold;" text="TEMPO MEDIO" />
                        <Label fx:id="lblAvgTime" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #3498db;" text="0 ms" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            
            <TableView fx:id="tblHistory" prefHeight="230.0" prefWidth="410.0" style="-fx-background-radius: 6; -fx-overflow-x: hidden;">
              <columns>
                <TableColumn fx:id="colOpponent" prefWidth="120.0" text="Avversario" />
